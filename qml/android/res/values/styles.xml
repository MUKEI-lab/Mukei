<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      Qt-compatible application theme. The brand splash uses only Android
      framework attributes so Qt's generated activity/application metadata
      remains untouched by the package-source overlay.
    -->
    <style name="MukeiAppTheme" parent="@android:style/Theme.Material.Light.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionModeOverlay">true</item>
        <item name="android:windowBackground">@drawable/mukei_splash_background</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:statusBarColor">@color/mukei_splash_background</item>
        <item name="android:navigationBarColor">@color/mukei_splash_background</item>
    </style>
</resources>
