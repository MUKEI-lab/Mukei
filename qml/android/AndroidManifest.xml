<?xml version="1.0" encoding="utf-8"?>
<!--
  Qt 6.5.3-compatible Android manifest for the Mukei QML shell.
  `QT_ANDROID_PACKAGE_SOURCE_DIR` points at this directory, so androiddeployqt
  replaces Qt insertion markers and copies these branded resources into the
  generated Gradle project.

  Do not replace this manifest with a branding-only overlay. Mandatory Qt
  activity metadata and insertion markers must remain present while launcher
  and splash branding is layered around them.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
          package="app.mukei"
          android:installLocation="auto"
          android:versionCode="705"
          android:versionName="0.7.5">
    <uses-sdk android:minSdkVersion="29" android:targetSdkVersion="35"/>

    <uses-permission android:name="android.permission.INTERNET"/>
    <!-- %%INSERT_PERMISSIONS -->
    <!-- %%INSERT_FEATURES -->

    <supports-screens
        android:anyDensity="true"
        android:largeScreens="true"
        android:normalScreens="true"
        android:smallScreens="true"/>

    <application
        android:name="org.qtproject.qt.android.bindings.QtApplication"
        android:label="Mukei"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:theme="@style/MukeiAppTheme"
        android:hardwareAccelerated="true"
        android:requestLegacyExternalStorage="false"
        android:allowNativeHeapPointerTagging="false"
        android:allowBackup="false"
        android:fullBackupOnly="false"
        android:hasFragileUserData="true"
        android:supportsRtl="true">
        <activity
            android:name="org.qtproject.qt.android.bindings.QtActivity"
            android:label="Mukei"
            android:exported="true"
            android:launchMode="singleTop"
            android:screenOrientation="unspecified"
            android:theme="@style/MukeiAppTheme"
            android:configChanges="orientation|uiMode|screenLayout|screenSize|smallestScreenSize|layoutDirection|locale|fontScale|keyboard|keyboardHidden|navigation|mcc|mnc|density">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>

            <meta-data
                android:name="android.app.lib_name"
                android:value="-- %%INSERT_APP_LIB_NAME%% --"/>
            <meta-data
                android:name="android.app.arguments"
                android:value="-- %%INSERT_APP_ARGUMENTS%% --"/>
            <meta-data
                android:name="android.app.extract_android_style"
                android:value="minimal"/>
            <meta-data
                android:name="android.app.splash_screen_drawable"
                android:resource="@drawable/mukei_splash_background"/>
        </activity>
    </application>
</manifest>
