<?xml version="1.0" encoding="utf-8"?>
<!--
  Android manifest for the Mukei QML shell. `QT_ANDROID_PACKAGE_SOURCE_DIR`
  in qml/CMakeLists.txt points at this directory, so androiddeployqt uses
  this file as the package-source manifest and overlays Qt's generated
  attributes on top of it. Network-backed provider/search and model download
  features require INTERNET to be declared here; Android does not grant that
  permission at runtime.

  minSdk 29 aligns with QT_ANDROID_MIN_SDK_VERSION in CMakeLists.txt;
  targetSdk 35 aligns with QT_ANDROID_TARGET_SDK_VERSION. versionCode uses
  major*10000 + minor*100 + patch and must increase for every APK release.

  Do not replace this manifest with the branding handoff: the handoff contains
  resources only. Qt-generated metadata and placeholders remain owned by
  androiddeployqt.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
          package="app.mukei"
          android:versionCode="705"
          android:versionName="0.7.5">
    <uses-sdk android:minSdkVersion="29" android:targetSdkVersion="35"/>

    <uses-permission android:name="android.permission.INTERNET"/>

    <application
        android:label="Mukei"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:theme="@style/MukeiAppTheme"
        android:allowBackup="false"
        android:hasFragileUserData="true"
        android:supportsRtl="true">
        <activity
            android:name="org.qtproject.qt.android.bindings.QtActivity"
            android:exported="true"
            android:theme="@style/MukeiAppTheme"
            android:configChanges="orientation|screenLayout|screenSize|smallestScreenSize|layoutDirection|locale|fontScale|keyboard|keyboardHidden|navigation|density|uiMode">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
    </application>
</manifest>
